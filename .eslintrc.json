{
  "env": { "node": true, "es2022": true },
  "parserOptions": { "ecmaVersion": 2022 },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "error",
    "no-unreachable": "error",
    "no-constant-condition": "error",
    "no-dupe-keys": "error",
    "no-duplicate-case": "error"
  },
  "overrides": [
    {
      "files": ["test/**/*.test.js"],
      "env": { "jest": true }
    }
  ]
}
